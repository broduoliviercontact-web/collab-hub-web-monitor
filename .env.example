# Adresse du serveur Collab-Hub (sans namespace ni slash final).
VITE_COLLAB_HUB_URL=https://server.collab-hub.io

# Namespace Socket.IO. DOIT correspondre au namespace du CH-Client Max
# (fixé par config.json du package Collab-Hub, défaut « hub »).
# Le serveur public v0.3.4 sert des namespaces séparés / et /hub (testé :
# ils ne se voient pas). Le CH-Client Max par défaut utilise /hub -> mettre hub.
# VIDE = namespace racine / (uniquement si votre Max utilise aussi la racine).
VITE_COLLAB_HUB_NAMESPACE=hub

# Mode d'authentification.
# anonymous = socket direct, SANS requête vers /api/v1/auth/guest
#   (mode attendu pour le serveur public v0.3.4, où cette route n'existe pas).
# guest     = tente l'auth invitée, retombe sur l'anonyme en cas d'échec
#   (serveur v0.5 disposant de /api/v1/auth/guest).
# Toute autre valeur -> anonymous (safe) + avertissement console discret.
VITE_COLLAB_HUB_AUTH_MODE=anonymous

# Activer socket.onAny au démarrage (mode diagnostic). 1 = oui.
VITE_DIAG_ONANY=1

# --- LiveKit (Lot 4C) : backend serverless, variables SERVEUR uniquement ---
# Ces 4 variables NE DOIVENT JAMAIS être préfixées par VITE_ : elles ne doivent
# pas être cuites dans le bundle navigateur. À configurer dans Vercel
# Environment Variables (Production + Preview), pas ici pour de vrai.
# Valeurs ci-dessous manifestement factices (refusées par l'endpoint token).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
PERFORMER_PASSWORD=change-me

# Active la section audio (Control Room) côté navigateur. false = désactivée
# (aucun impact sur la page publique). Ne PAS passer à true dans ce lot.
VITE_LIVEKIT_ENABLED=false